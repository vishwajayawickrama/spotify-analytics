# Ballerina configurable values for the spotify_integration service.
# LOCAL DEVELOPMENT profile.
# Copy to `Config.toml` and adjust as needed. See:
# https://ballerina.io/learn/provide-values-to-configurable-variables/

spotifyApiUrl = "https://api.spotify.com/v1"
spotifyAccountsApiUrl = "https://accounts.spotify.com"

spotifyClientId = "<spotify-client-id>"
spotifyClientSecret = "<spotify-client-secret>"

servicePort = 8080

# Origin allowed by CORS — the URL where the frontend is served.
allowedOrigin = "http://localhost:3000"

# Frontend URL used for redirects after login.
frontendBaseUrl = "http://localhost:3000"

# Spotify callback URL handled by this Ballerina service.
oauthCallbackUrl = "http://127.0.0.1:8080/auth/callback"

# Cookie name for backend-managed auth session.
sessionCookieName = "spotify_access_token"

# For production values, use `Config.production.toml.example`.
