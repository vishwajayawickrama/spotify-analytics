# ---- NextAuth ----
# Generate a random secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=replace-with-random-string
NEXTAUTH_URL=http://localhost:3000

# ---- Spotify OAuth app credentials ----
# Create an app at https://developer.spotify.com/dashboard
# Add this redirect URI to the app:
#   http://localhost:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ---- Backend (Ballerina analytics service) ----
# Public base URL of the Ballerina analytics API the browser will call.
NEXT_PUBLIC_ANALYTICS_API=http://localhost:8080/analytics
