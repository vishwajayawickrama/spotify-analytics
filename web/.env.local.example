# Spotify OAuth app credentials. Create at https://developer.spotify.com/dashboard
# Add http://localhost:3000/api/auth/callback/spotify as an Authorized Redirect URI.
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# Random 32+ char secret used by NextAuth to sign session JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000

# Base URL of the Ballerina backend service.
NEXT_PUBLIC_BACKEND_BASE=https://ec58c6af-699d-47f9-b160-e155e9dd5fed-dev.e1-us-east-azure.choreoapis.dev/spotify-analytics/spotifyintegration/v1.0
NEXT_PUBLIC_ANALYTICS_API=https://ec58c6af-699d-47f9-b160-e155e9dd5fed-dev.e1-us-east-azure.choreoapis.dev/spotify-analytics/spotifyintegration/v1.0/analytics
